import React, { useMemo, useState, useEffect } from 'react';
import {
  X, User, Mail, Phone, MapPin, Building, CreditCard, ShoppingCart,
  Wallet, FileText, BarChart3, Banknote, Download, AlertCircle, CheckCircle2,
  Percent, Receipt, TrendingUp, Calendar, Clock, Edit, History, ArrowRight
} from 'lucide-react';
import { Customer, ClientQuota } from '../../types';
import { useDataContext } from '../../contexts/DataContext';
import { formatCurrency, getSettings, AppSettings } from '../../services/settings';
import { quotasAPI, customersAPI } from '../../services/mysql-api';

// Type pour les dépôts avec traçabilité
interface DepositAllocation {
  saleId: string;
  saleNumber: string;
  saleDate: string;
  saleTotal: number;
  productDetails: string;
  amountAllocated: number;
  previousBalance: number;
  newBalance: number;
}

interface ClientDeposit {
  id: number;
  deposit_number: string;
  amount: number;
  amount_to_debt: number;
  amount_to_prepaid: number;
  payment_method: string;
  reference_number: string | null;
  notes: string | null;
  previous_debt: number;
  new_debt: number;
  previous_prepaid: number;
  new_prepaid: number;
  created_at: string;
  allocations: DepositAllocation[];
}

interface CustomerDetailProps {
  customer: Customer;
  onClose: () => void;
  onEdit: () => void;
}

export const CustomerDetail: React.FC<CustomerDetailProps> = ({ customer, onClose, onEdit }) => {
  const { sales } = useDataContext();
  const [settings, setSettings] = useState<AppSettings | null>(null);
  const [quotas, setQuotas] = useState<ClientQuota[]>([]);
  const [quotaLoading, setQuotaLoading] = useState(false);
  const [deposits, setDeposits] = useState<ClientDeposit[]>([]);
  const [depositsLoading, setDepositsLoading] = useState(false);
  const [activeTab, setActiveTab] = useState<'overview' | 'sales' | 'quotas' | 'deposits' | 'notes'>('overview');
  const [generatingPdf, setGeneratingPdf] = useState(false);

  useEffect(() => {
    getSettings().then(setSettings);
  }, []);

  // Extract customer properties (moved up to use in useEffect)
  const customerType = (customer as any)?.customerType || (customer as any)?.customer_type || 'simple';

  // Load quotas for quotataire customers
  useEffect(() => {
    const loadQuotas = async () => {
      if (!customer?.id || customerType !== 'quotataire') return;
      setQuotaLoading(true);
      try {
        const result = await quotasAPI.getAll({ customer_id: customer.id });
        if (result.success) setQuotas(result.data || []);
      } catch (e) {
        console.error('Erreur chargement quotas:', e);
      } finally {
        setQuotaLoading(false);
      }
    };
    loadQuotas();
  }, [customer?.id, customerType]);

  // Load deposits history with full traceability
  useEffect(() => {
    const loadDeposits = async () => {
      if (!customer?.id) return;
      setDepositsLoading(true);
      try {
        const result = await customersAPI.getDeposits(customer.id);
        if (result.success) setDeposits(result.data || []);
      } catch (e) {
        console.error('Erreur chargement dépôts:', e);
      } finally {
        setDepositsLoading(false);
      }
    };
    loadDeposits();
  }, [customer?.id]);

  const fmt = (amount: number) => formatCurrency(amount, settings || undefined);

  // Extract remaining customer properties
  const prepaidBalance = Number((customer as any)?.prepaidBalance ?? (customer as any)?.prepaid_balance ?? 0);
  const creditLimit = Number((customer as any)?.creditLimit ?? (customer as any)?.credit_limit ?? 0);
  const balance = Number((customer as any)?.balance ?? (customer as any)?.current_balance ?? 0); // dette
  const tvaExempt = !!(customer as any)?.tva_exempt;
  const isReseller = !!(customer as any)?.is_reseller;
  const wholesaleDiscount = Number((customer as any)?.wholesale_discount ?? 0);
  const notes = (customer as any)?.notes || '';
  const city = (customer as any)?.city || '';
  const address = (customer as any)?.address || '';
  const company = (customer as any)?.company || '';

  const customerSales = useMemo(() => {
    return (sales || []).filter((s: any) => s.customerId === customer.id || s.customer_id === customer.id);
  }, [sales, customer.id]);

  const totalSales = customerSales.length;

  const totalAmount = useMemo(() => {
    return customerSales.reduce((sum: number, sale: any) => {
      const v =
        Number(sale?.total ?? 0) ||
        Number(sale?.total_amount ?? 0) ||
        Number(sale?.totalAmount ?? 0) ||
        0;
      return sum + v;
    }, 0);
  }, [customerSales]);

  // Calculate paid vs unpaid
  const paidAmount = useMemo(() => {
    return customerSales.reduce((sum: number, sale: any) => {
      if (sale?.status === 'paid' || sale?.payment_status === 'paid') {
        const v = Number(sale?.total ?? 0) || Number(sale?.total_amount ?? 0) || 0;
        return sum + v;
      }
      return sum;
    }, 0);
  }, [customerSales]);

  const getTypeColor = () => {
    switch (customerType) {
      case 'quotataire': return 'bg-violet-100 text-violet-700 border-violet-200';
      case 'revendeur': return 'bg-amber-100 text-amber-700 border-amber-200';
      default: return 'bg-gray-100 text-gray-600 border-gray-200';
    }
  };

  const getTypeLabel = () => {
    switch (customerType) {
      case 'quotataire': return 'Client Quotataire';
      case 'revendeur': return 'Revendeur';
      default: return 'Client Simple';
    }
  };

  // Generate PDF
  const handleGeneratePdf = async () => {
    setGeneratingPdf(true);
    try {
      const API_BASE_URL = import.meta.env.VITE_API_URL || 'http://localhost:3001/api';
      const token = localStorage.getItem('auth_token');

      const response = await fetch(`${API_BASE_URL}/pdf/customer-statement/${customer.id}`, {
        method: 'GET',
        headers: {
          'Authorization': `Bearer ${token}`,
        },
      });

      if (!response.ok) {
        throw new Error('Erreur lors de la génération du PDF');
      }

      const blob = await response.blob();
      const url = window.URL.createObjectURL(blob);
      const a = document.createElement('a');
      a.href = url;
      a.download = `etat-client-${customer.name.replace(/\s+/g, '-')}-${new Date().toISOString().split('T')[0]}.pdf`;
      document.body.appendChild(a);
      a.click();
      window.URL.revokeObjectURL(url);
      document.body.removeChild(a);
    } catch (error) {
      console.error('Erreur PDF:', error);
      alert('Erreur lors de la génération du PDF. Veuillez réessayer.');
    } finally {
      setGeneratingPdf(false);
    }
  };

  const tabs = [
    { key: 'overview', label: 'Aperçu', icon: User },
    { key: 'sales', label: 'Achats', icon: ShoppingCart },
    ...(customerType === 'quotataire' ? [{ key: 'quotas', label: 'Quotas', icon: BarChart3 }] : []),
    { key: 'deposits', label: 'Dépôts', icon: History },
    ...(notes ? [{ key: 'notes', label: 'Notes', icon: FileText }] : []),
  ];

  return (
    <div className="fixed inset-0 bg-slate-900/40 backdrop-blur-sm z-50 flex items-center justify-center p-4">
      <div className="bg-white rounded-2xl shadow-2xl max-w-4xl w-full max-h-[90vh] flex flex-col">
        {/* Header */}
        <div className="flex items-center justify-between p-5 border-b border-gray-200">
          <div className="flex items-center gap-4">
            <div className={`w-14 h-14 rounded-xl flex items-center justify-center font-bold text-xl flex-shrink-0 ${
              customerType === 'quotataire' ? 'bg-violet-100 text-violet-700' :
              customerType === 'revendeur' ? 'bg-amber-100 text-amber-700' :
              'bg-blue-100 text-blue-700'
            }`}>
              {customer.name?.charAt(0)?.toUpperCase() || '?'}
            </div>
            <div>
              <div className="flex items-center gap-2">
                <h2 className="text-lg font-bold text-gray-900">{customer.name}</h2>
                <span className={`px-2.5 py-0.5 rounded-full text-xs font-medium border ${getTypeColor()}`}>
                  {getTypeLabel()}
                </span>
              </div>
              <p className="text-sm text-gray-500">{company || 'Client particulier'}</p>
            </div>
          </div>

          <div className="flex items-center gap-2">
            <button
              onClick={handleGeneratePdf}
              disabled={generatingPdf}
              className="flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white text-sm font-medium rounded-lg hover:bg-emerald-700 disabled:opacity-50 transition-colors"
              type="button"
            >
              {generatingPdf ? (
                <>
                  <div className="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin" />
                  Génération...
                </>
              ) : (
                <>
                  <Download className="w-4 h-4" />
                  PDF
                </>
              )}
            </button>
            <button
              onClick={onEdit}
              className="px-4 py-2 bg-blue-600 text-white text-sm font-medium rounded-lg hover:bg-blue-700 transition-colors"
              type="button"
            >
              Modifier
            </button>
            <button
              onClick={onClose}
              className="w-8 h-8 flex items-center justify-center text-gray-400 hover:text-gray-600 hover:bg-gray-100 rounded-lg transition-colors"
              type="button"
            >
              <X className="w-5 h-5" />
            </button>
          </div>
        </div>

        {/* Tabs */}
        <div className="flex items-center gap-2 px-5 py-3 border-b border-gray-100 overflow-x-auto">
          {tabs.map((tab) => (
            <button
              key={tab.key}
              type="button"
              onClick={() => setActiveTab(tab.key as any)}
              className={`flex items-center gap-2 px-4 py-2 rounded-lg whitespace-nowrap text-sm font-medium transition-colors ${
                activeTab === tab.key
                  ? 'bg-blue-600 text-white'
                  : 'bg-gray-100 text-gray-600 hover:bg-gray-200'
              }`}
            >
              <tab.icon className="w-4 h-4" />
              {tab.label}
            </button>
          ))}
        </div>

        {/* Body */}
        <div className="flex-1 overflow-y-auto p-5 space-y-5">
          {/* Tab: Overview */}
          {activeTab === 'overview' && (
            <>
              {/* Quick Stats */}
              <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
                {customerType === 'quotataire' ? (
                  <div className="bg-gradient-to-br from-violet-50 to-purple-50 rounded-xl p-4 border border-violet-100">
                    <div className="flex items-center gap-2 text-violet-600 mb-1">
                      <Banknote className="w-4 h-4" />
                      <span className="text-xs font-medium">Solde Prépayé</span>
                    </div>
                    <p className={`text-xl font-bold ${prepaidBalance > 0 ? 'text-violet-700' : 'text-red-500'}`}>
                      {fmt(prepaidBalance)}
                    </p>
                  </div>
                ) : (
                  <div className="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-4 border border-blue-100">
                    <div className="flex items-center gap-2 text-blue-600 mb-1">
                      <CreditCard className="w-4 h-4" />
                      <span className="text-xs font-medium">Limite Crédit</span>
                    </div>
                    <p className="text-xl font-bold text-blue-700">{fmt(creditLimit)}</p>
                  </div>
                )}

                <div className="bg-gradient-to-br from-amber-50 to-orange-50 rounded-xl p-4 border border-amber-100">
                  <div className="flex items-center gap-2 text-amber-600 mb-1">
                    <Wallet className="w-4 h-4" />
                    <span className="text-xs font-medium">Dette</span>
                  </div>
                  <p className={`text-xl font-bold ${balance > 0 ? 'text-red-600' : 'text-emerald-600'}`}>
                    {fmt(balance)}
                  </p>
                </div>

                <div className="bg-gradient-to-br from-emerald-50 to-green-50 rounded-xl p-4 border border-emerald-100">
                  <div className="flex items-center gap-2 text-emerald-600 mb-1">
                    <TrendingUp className="w-4 h-4" />
                    <span className="text-xs font-medium">Total Achats</span>
                  </div>
                  <p className="text-xl font-bold text-emerald-700">{fmt(totalAmount)}</p>
                </div>

                <div className="bg-gradient-to-br from-slate-50 to-gray-50 rounded-xl p-4 border border-gray-100">
                  <div className="flex items-center gap-2 text-gray-600 mb-1">
                    <Receipt className="w-4 h-4" />
                    <span className="text-xs font-medium">Commandes</span>
                  </div>
                  <p className="text-xl font-bold text-gray-700">{totalSales}</p>
                </div>
              </div>

              {/* Contact & Fiscal Info */}
              <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                {/* Contact */}
                <div className="bg-gray-50 rounded-xl p-4 border border-gray-100">
                  <h3 className="text-sm font-semibold text-gray-700 mb-3 flex items-center gap-2">
                    <User className="w-4 h-4 text-blue-500" />
                    Informations de Contact
                  </h3>
                  <div className="space-y-3">
                    <div className="flex items-start gap-3">
                      <Mail className="w-4 h-4 text-gray-400 mt-0.5" />
                      <div>
                        <p className="text-xs text-gray-500">Email</p>
                        <p className="text-sm text-gray-700 font-medium">{(customer as any).email || '—'}</p>
                      </div>
                    </div>
                    <div className="flex items-start gap-3">
                      <Phone className="w-4 h-4 text-gray-400 mt-0.5" />
                      <div>
                        <p className="text-xs text-gray-500">Téléphone</p>
                        <p className="text-sm text-gray-700 font-medium">{(customer as any).phone || '—'}</p>
                      </div>
                    </div>
                    <div className="flex items-start gap-3">
                      <MapPin className="w-4 h-4 text-gray-400 mt-0.5" />
                      <div>
                        <p className="text-xs text-gray-500">Adresse</p>
                        <p className="text-sm text-gray-700 font-medium">{address || '—'}</p>
                        {city && <p className="text-sm text-gray-500">{city}</p>}
                      </div>
                    </div>
                    {company && (
                      <div className="flex items-start gap-3">
                        <Building className="w-4 h-4 text-gray-400 mt-0.5" />
                        <div>
                          <p className="text-xs text-gray-500">Entreprise</p>
                          <p className="text-sm text-gray-700 font-medium">{company}</p>
                        </div>
                      </div>
                    )}
                  </div>
                </div>

                {/* Fiscal Parameters */}
                <div className="bg-gray-50 rounded-xl p-4 border border-gray-100">
                  <h3 className="text-sm font-semibold text-gray-700 mb-3 flex items-center gap-2">
                    <BarChart3 className="w-4 h-4 text-blue-500" />
                    Paramètres Fiscaux
                  </h3>
                  <div className="space-y-3">
                    <div className="flex items-center justify-between p-2.5 bg-white rounded-lg border border-gray-100">
                      <div className="flex items-center gap-2">
                        <Percent className="w-4 h-4 text-gray-400" />
                        <span className="text-sm text-gray-600">Exonéré TVA</span>
                      </div>
                      <span className={`px-2.5 py-1 rounded-full text-xs font-medium ${
                        tvaExempt ? 'bg-emerald-100 text-emerald-700' : 'bg-gray-100 text-gray-500'
                      }`}>
                        {tvaExempt ? 'Oui' : 'Non'}
                      </span>
                    </div>

                    <div className="flex items-center justify-between p-2.5 bg-white rounded-lg border border-gray-100">
                      <div className="flex items-center gap-2">
                        <Building className="w-4 h-4 text-gray-400" />
                        <span className="text-sm text-gray-600">Revendeur</span>
                      </div>
                      <span className={`px-2.5 py-1 rounded-full text-xs font-medium ${
                        isReseller ? 'bg-amber-100 text-amber-700' : 'bg-gray-100 text-gray-500'
                      }`}>
                        {isReseller ? 'Oui' : 'Non'}
                      </span>
                    </div>

                    {isReseller && (
                      <div className="flex items-center justify-between p-2.5 bg-amber-50 rounded-lg border border-amber-100">
                        <div className="flex items-center gap-2">
                          <Percent className="w-4 h-4 text-amber-500" />
                          <span className="text-sm text-amber-700">Remise Grossiste</span>
                        </div>
                        <span className="px-2.5 py-1 bg-amber-200 text-amber-800 rounded-full text-xs font-bold">
                          {wholesaleDiscount}%
                        </span>
                      </div>
                    )}

                    {/* Credit Info for non-quotataires */}
                    {customerType !== 'quotataire' && creditLimit > 0 && (
                      <div className="mt-3 pt-3 border-t border-gray-200">
                        <div className="flex justify-between text-sm mb-2">
                          <span className="text-gray-500">Utilisation du crédit</span>
                          <span className={`font-bold ${
                            (balance / creditLimit) > 0.8 ? 'text-red-600' : 'text-emerald-600'
                          }`}>
                            {Math.round((balance / creditLimit) * 100)}%
                          </span>
                        </div>
                        <div className="h-2 bg-gray-200 rounded-full overflow-hidden">
                          <div
                            className={`h-full rounded-full transition-all ${
                              (balance / creditLimit) > 0.8 ? 'bg-red-500' : 'bg-emerald-500'
                            }`}
                            style={{ width: `${Math.min(100, (balance / creditLimit) * 100)}%` }}
                          />
                        </div>
                        <p className="text-xs text-gray-500 mt-1.5">
                          Disponible: <span className="font-medium text-gray-700">{fmt(creditLimit - balance)}</span>
                        </p>
                      </div>
                    )}
                  </div>
                </div>
              </div>

              {/* Alert for low balance or high debt */}
              {customerType === 'quotataire' && prepaidBalance <= 50000 && (
                <div className={`flex items-center gap-3 p-3 rounded-lg ${
                  prepaidBalance <= 0 ? 'bg-red-50 border border-red-200' : 'bg-amber-50 border border-amber-200'
                }`}>
                  <AlertCircle className={`w-5 h-5 ${prepaidBalance <= 0 ? 'text-red-500' : 'text-amber-500'}`} />
                  <div>
                    <p className={`text-sm font-medium ${prepaidBalance <= 0 ? 'text-red-700' : 'text-amber-700'}`}>
                      {prepaidBalance <= 0 ? 'Solde prépayé épuisé' : 'Solde prépayé faible'}
                    </p>
                    <p className={`text-xs ${prepaidBalance <= 0 ? 'text-red-600' : 'text-amber-600'}`}>
                      {prepaidBalance <= 0
                        ? 'Ce client ne peut plus effectuer d\'achats sans recharger son solde.'
                        : 'Pensez à recharger le solde prépayé de ce client.'}
                    </p>
                  </div>
                </div>
              )}

              {balance > 0 && (
                <div className="flex items-center gap-3 p-3 rounded-lg bg-red-50 border border-red-200">
                  <AlertCircle className="w-5 h-5 text-red-500" />
                  <div>
                    <p className="text-sm font-medium text-red-700">Ce client a une dette de {fmt(balance)}</p>
                    <p className="text-xs text-red-600">
                      Lors du prochain dépôt, la dette sera remboursée en priorité.
                    </p>
                  </div>
                </div>
              )}
            </>
          )}

          {/* Tab: Sales */}
          {activeTab === 'sales' && (
            <div>
              <div className="flex items-center justify-between mb-4">
                <h3 className="text-sm font-semibold text-gray-700 flex items-center gap-2">
                  <ShoppingCart className="w-4 h-4 text-gray-500" />
                  Historique des achats ({customerSales.length})
                </h3>
                <div className="flex items-center gap-3 text-sm">
                  <span className="text-gray-500">Total: <span className="font-medium text-gray-900">{fmt(totalAmount)}</span></span>
                  <span className="text-gray-500">Payé: <span className="font-medium text-emerald-600">{fmt(paidAmount)}</span></span>
                  <span className="text-gray-500">Impayé: <span className="font-medium text-red-600">{fmt(totalAmount - paidAmount)}</span></span>
                </div>
              </div>

              {customerSales.length > 0 ? (
                <div className="rounded-xl border border-gray-200 overflow-hidden">
                  <table className="w-full text-sm">
                    <thead className="bg-gray-50">
                      <tr>
                        <th className="px-4 py-2.5 text-left font-medium text-gray-600">N° / Date</th>
                        <th className="px-4 py-2.5 text-left font-medium text-gray-600">Produits</th>
                        <th className="px-4 py-2.5 text-right font-medium text-gray-600">Montant</th>
                        <th className="px-4 py-2.5 text-right font-medium text-gray-600">Reste dû</th>
                        <th className="px-4 py-2.5 text-center font-medium text-gray-600">Statut</th>
                      </tr>
                    </thead>
                    <tbody className="bg-white">
                      {customerSales.slice().sort((a: any, b: any) => {
                        const dateA = new Date(a?.sale_date || a?.created_at || 0).getTime();
                        const dateB = new Date(b?.sale_date || b?.created_at || 0).getTime();
                        return dateB - dateA;
                      }).map((sale: any) => {
                        const amount =
                          Number(sale?.total ?? 0) ||
                          Number(sale?.total_amount ?? 0) ||
                          Number(sale?.totalAmount ?? 0) ||
                          0;
                        const paidSale = Number(sale?.amount_paid ?? sale?.amountPaid ?? 0);
                        const remaining = Math.max(0, amount - paidSale);
                        const createdAt = sale?.sale_date || sale?.createdAt || sale?.created_at || sale?.date || new Date().toISOString();
                        const status = sale?.status || sale?.payment_status || 'draft';
                        const items = sale?.items || sale?.sale_items || [];
                        const productSummary = items.length > 0 
                          ? items.slice(0, 2).map((i: any) => i.productName || i.product_name || 'Produit').join(', ') + (items.length > 2 ? ` +${items.length - 2}` : '')
                          : '—';

                        return (
                          <tr key={sale.id} className="border-b border-gray-100 hover:bg-gray-50">
                            <td className="px-4 py-3">
                              <p className="font-medium text-gray-800">
                                #{sale.sale_number || (typeof sale.id === 'string' ? sale.id.substring(0, 8) : sale.id)}
                              </p>
                              <p className="text-xs text-gray-400 flex items-center gap-1">
                                <Calendar className="w-3 h-3" />
                                {new Date(createdAt).toLocaleDateString('fr-FR', { day: '2-digit', month: 'short', year: 'numeric' })}
                              </p>
                            </td>
                            <td className="px-4 py-3 text-gray-600 text-xs max-w-[200px] truncate" title={productSummary}>
                              {productSummary}
                            </td>
                            <td className="px-4 py-3 text-right font-medium text-gray-800">{fmt(amount)}</td>
                            <td className="px-4 py-3 text-right">
                              <span className={`font-medium ${remaining > 0 ? 'text-red-600' : 'text-emerald-600'}`}>
                                {remaining > 0 ? fmt(remaining) : '—'}
                              </span>
                            </td>
                            <td className="px-4 py-3 text-center">
                              <span className={`inline-flex items-center gap-1 px-2 py-1 text-xs font-medium rounded-md ${
                                status === 'paid'
                                  ? 'bg-emerald-100 text-emerald-700'
                                  : status === 'confirmed'
                                  ? 'bg-blue-100 text-blue-700'
                                  : status === 'cancelled'
                                  ? 'bg-red-100 text-red-700'
                                  : 'bg-amber-100 text-amber-700'
                              }`}>
                                {status === 'paid' && <CheckCircle2 className="w-3 h-3" />}
                                {status === 'paid' ? 'Payé' : status === 'confirmed' ? 'Confirmé' : status === 'cancelled' ? 'Annulé' : 'En attente'}
                              </span>
                            </td>
                          </tr>
                        );
                      })}
                    </tbody>
                  </table>
                </div>
              ) : (
                <div className="text-center py-12 bg-gray-50 rounded-xl border border-gray-100">
                  <ShoppingCart className="w-12 h-12 text-gray-300 mx-auto mb-3" />
                  <p className="text-gray-500 font-medium">Aucune commande</p>
                  <p className="text-sm text-gray-400">Ce client n'a pas encore effectué d'achats</p>
                </div>
              )}
            </div>
          )}

          {/* Tab: Quotas (for quotataires only) */}
          {activeTab === 'quotas' && customerType === 'quotataire' && (
            <div className="space-y-5">
              {/* Header avec bouton */}
              <div className="flex items-center justify-between">
                <h3 className="text-base font-bold text-gray-800 flex items-center gap-2">
                  <BarChart3 className="w-5 h-5 text-violet-600" />
                  État des Quotas
                </h3>
                <button
                  onClick={onEdit}
                  className="flex items-center gap-1.5 px-3 py-1.5 bg-violet-100 text-violet-700 rounded-lg text-xs font-medium hover:bg-violet-200 transition-colors"
                >
                  <Wallet className="w-3.5 h-3.5" />
                  Gérer les quotas
                </button>
              </div>

              {quotaLoading ? (
                <div className="flex flex-col items-center justify-center py-12">
                  <div className="w-12 h-12 border-4 border-violet-200 border-t-violet-600 rounded-full animate-spin" />
                  <p className="text-sm text-gray-500 mt-4">Chargement des quotas...</p>
                </div>
              ) : quotas.length > 0 ? (
                <div className="space-y-5">
                  {/* Résumé Global */}
                  <div className="grid grid-cols-2 md:grid-cols-4 gap-3">
                    <div className="p-3 bg-gradient-to-br from-violet-50 to-purple-50 border border-violet-100 rounded-xl text-center">
                      <p className="text-2xl font-bold text-violet-700">{quotas.length}</p>
                      <p className="text-xs text-violet-500 font-medium">Produits</p>
                    </div>
                    <div className="p-3 bg-gradient-to-br from-blue-50 to-indigo-50 border border-blue-100 rounded-xl text-center">
                      <p className="text-2xl font-bold text-blue-700">
                        {quotas.reduce((sum, q) => sum + Number(q.quota_initial || 0), 0).toLocaleString('fr-FR')}
                      </p>
                      <p className="text-xs text-blue-500 font-medium">Tonnes Total</p>
                    </div>
                    <div className="p-3 bg-gradient-to-br from-orange-50 to-amber-50 border border-orange-100 rounded-xl text-center">
                      <p className="text-2xl font-bold text-orange-600">
                        {quotas.reduce((sum, q) => sum + Number(q.quota_consumed || 0), 0).toLocaleString('fr-FR')}
                      </p>
                      <p className="text-xs text-orange-500 font-medium">Tonnes Consommées</p>
                    </div>
                    <div className="p-3 bg-gradient-to-br from-emerald-50 to-green-50 border border-emerald-100 rounded-xl text-center">
                      <p className="text-2xl font-bold text-emerald-600">
                        {quotas.reduce((sum, q) => sum + Number(q.quota_remaining || 0), 0).toLocaleString('fr-FR')}
                      </p>
                      <p className="text-xs text-emerald-500 font-medium">Tonnes Restantes</p>
                    </div>
                  </div>

                  {/* Liste détaillée des quotas */}
                  <div className="bg-white rounded-xl border border-gray-200 overflow-hidden shadow-sm">
                    <div className="bg-gradient-to-r from-violet-600 to-purple-600 px-4 py-3">
                      <h4 className="text-white font-semibold text-sm flex items-center gap-2">
                        <TrendingUp className="w-4 h-4" />
                        Détail par Produit
                      </h4>
                    </div>
                    <div className="divide-y divide-gray-100">
                      {quotas.map((q) => {
                        const progress = q.quota_initial > 0 ? ((q.quota_consumed || 0) / q.quota_initial) * 100 : 0;
                        const remaining = Number(q.quota_remaining || 0);
                        const isCompleted = q.status === 'completed' || remaining <= 0;
                        const isLow = remaining > 0 && remaining < q.quota_initial * 0.2;
                        const isCritical = remaining > 0 && remaining < q.quota_initial * 0.1;

                        return (
                          <div key={q.id} className={`p-4 ${isCompleted ? 'bg-gray-50 opacity-75' : 'hover:bg-gray-50'} transition-colors`}>
                            {/* Header du quota */}
                            <div className="flex items-start justify-between mb-4">
                              <div className="flex items-center gap-3">
                                <div className={`w-12 h-12 rounded-xl flex items-center justify-center shadow-sm ${
                                  q.product_type === 'beton' 
                                    ? 'bg-gradient-to-br from-blue-100 to-blue-200 text-blue-600' 
                                    : 'bg-gradient-to-br from-amber-100 to-amber-200 text-amber-600'
                                }`}>
                                  <BarChart3 className="w-6 h-6" />
                                </div>
                                <div>
                                  <h5 className="font-bold text-gray-900 text-base">
                                    {q.product_type === 'beton' ? 'Béton' : 'Carrière'} {q.product_variant}
                                  </h5>
                                  <p className="text-xs text-gray-500 flex items-center gap-1">
                                    <Clock className="w-3 h-3" />
                                    Créé le {new Date(q.created_at || Date.now()).toLocaleDateString('fr-FR', {
                                      day: 'numeric', month: 'short', year: 'numeric'
                                    })}
                                  </p>
                                </div>
                              </div>
                              <div className="flex items-center gap-2">
                                {isCompleted && (
                                  <span className="px-3 py-1.5 bg-gray-100 text-gray-600 text-xs font-bold rounded-full flex items-center gap-1.5 shadow-sm">
                                    <AlertCircle className="w-3.5 h-3.5" />
                                    Épuisé
                                  </span>
                                )}
                                {isCritical && !isCompleted && (
                                  <span className="px-3 py-1.5 bg-red-100 text-red-600 text-xs font-bold rounded-full flex items-center gap-1.5 shadow-sm animate-pulse">
                                    <AlertCircle className="w-3.5 h-3.5" />
                                    Critique !
                                  </span>
                                )}
                                {isLow && !isCritical && !isCompleted && (
                                  <span className="px-3 py-1.5 bg-amber-100 text-amber-600 text-xs font-bold rounded-full flex items-center gap-1.5 shadow-sm">
                                    <AlertCircle className="w-3.5 h-3.5" />
                                    Stock Bas
                                  </span>
                                )}
                                {!isLow && !isCompleted && (
                                  <span className="px-3 py-1.5 bg-emerald-100 text-emerald-600 text-xs font-bold rounded-full flex items-center gap-1.5 shadow-sm">
                                    <CheckCircle2 className="w-3.5 h-3.5" />
                                    Actif
                                  </span>
                                )}
                              </div>
                            </div>

                            {/* Statistiques */}
                            <div className="grid grid-cols-3 gap-3 mb-4">
                              <div className="bg-blue-50 rounded-xl p-3 text-center border border-blue-100">
                                <p className="text-xs text-blue-500 font-medium mb-1">Quota Alloué</p>
                                <p className="text-xl font-bold text-blue-700">{Number(q.quota_initial).toLocaleString('fr-FR')}</p>
                                <p className="text-xs text-blue-400">Tonnes</p>
                              </div>
                              <div className="bg-orange-50 rounded-xl p-3 text-center border border-orange-100">
                                <p className="text-xs text-orange-500 font-medium mb-1">Consommé</p>
                                <p className="text-xl font-bold text-orange-600">{Number(q.quota_consumed || 0).toLocaleString('fr-FR')}</p>
                                <p className="text-xs text-orange-400">{Math.round(progress)}% utilisé</p>
                              </div>
                              <div className={`rounded-xl p-3 text-center border ${
                                isCompleted ? 'bg-gray-50 border-gray-200' :
                                isCritical ? 'bg-red-50 border-red-100' :
                                isLow ? 'bg-amber-50 border-amber-100' : 'bg-emerald-50 border-emerald-100'
                              }`}>
                                <p className={`text-xs font-medium mb-1 ${
                                  isCompleted ? 'text-gray-500' :
                                  isCritical ? 'text-red-500' :
                                  isLow ? 'text-amber-500' : 'text-emerald-500'
                                }`}>Disponible</p>
                                <p className={`text-xl font-bold ${
                                  isCompleted ? 'text-gray-600' :
                                  isCritical ? 'text-red-600' :
                                  isLow ? 'text-amber-600' : 'text-emerald-600'
                                }`}>{remaining.toLocaleString('fr-FR')}</p>
                                <p className={`text-xs ${
                                  isCompleted ? 'text-gray-400' :
                                  isCritical ? 'text-red-400' :
                                  isLow ? 'text-amber-400' : 'text-emerald-400'
                                }`}>Tonnes</p>
                              </div>
                            </div>

                            {/* Barre de progression */}
                            <div>
                              <div className="flex justify-between text-xs text-gray-500 mb-2">
                                <span className="font-medium">Progression</span>
                                <span className="font-bold text-gray-700">{Math.round(progress)}%</span>
                              </div>
                              <div className="h-3 bg-gray-100 rounded-full overflow-hidden shadow-inner">
                                <div
                                  className={`h-full rounded-full transition-all duration-700 ${
                                    progress >= 100 ? 'bg-gradient-to-r from-red-500 to-red-600' :
                                    progress >= 90 ? 'bg-gradient-to-r from-red-400 to-red-500' :
                                    progress >= 80 ? 'bg-gradient-to-r from-amber-400 to-amber-500' :
                                    progress >= 50 ? 'bg-gradient-to-r from-violet-400 to-violet-500' :
                                    'bg-gradient-to-r from-violet-500 to-purple-500'
                                  }`}
                                  style={{ width: `${Math.min(100, progress)}%` }}
                                />
                              </div>
                            </div>

                            {/* Notes si présentes */}
                            {q.notes && (
                              <div className="mt-3 p-2.5 bg-gray-50 rounded-lg border border-gray-100">
                                <p className="text-xs text-gray-600">📝 {q.notes}</p>
                              </div>
                            )}
                          </div>
                        );
                      })}
                    </div>
                  </div>
                </div>
              ) : (
                <div className="text-center py-16 bg-gradient-to-br from-violet-50 to-purple-50 rounded-2xl border-2 border-dashed border-violet-200">
                  <div className="w-20 h-20 bg-violet-100 rounded-2xl flex items-center justify-center mx-auto mb-4 shadow-sm">
                    <BarChart3 className="w-10 h-10 text-violet-400" />
                  </div>
                  <h4 className="text-lg font-bold text-gray-700">Aucun quota défini</h4>
                  <p className="text-sm text-gray-500 mt-1 max-w-sm mx-auto">
                    Les quotas permettent de suivre la consommation de ce client sur des produits spécifiques
                  </p>
                  <button
                    onClick={onEdit}
                    className="mt-5 inline-flex items-center gap-2 px-5 py-2.5 bg-violet-600 text-white rounded-xl text-sm font-semibold hover:bg-violet-700 transition-colors shadow-lg shadow-violet-200"
                  >
                    <Wallet className="w-4 h-4" />
                    Créer un quota
                  </button>
                </div>
              )}
            </div>
          )}

          {/* Tab: Dépôts - Historique complet avec traçabilité */}
          {activeTab === 'deposits' && (
            <div className="space-y-4">
              {/* En-tête */}
              <div className="flex items-center justify-between">
                <h3 className="text-lg font-semibold text-gray-800 flex items-center gap-2">
                  <History className="w-5 h-5 text-emerald-500" />
                  Historique des dépôts
                </h3>
                <span className="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-full">
                  {deposits.length} dépôt(s)
                </span>
              </div>

              {depositsLoading ? (
                <div className="flex justify-center py-12">
                  <div className="animate-spin rounded-full h-8 w-8 border-2 border-emerald-500 border-t-transparent"></div>
                </div>
              ) : deposits.length > 0 ? (
                <div className="space-y-4">
                  {/* Résumé */}
                  <div className="grid grid-cols-3 gap-3">
                    <div className="bg-gradient-to-br from-emerald-50 to-green-50 rounded-xl p-4 text-center border border-emerald-200">
                      <p className="text-xs text-emerald-600 mb-1">Total déposé</p>
                      <p className="text-xl font-bold text-emerald-700">
                        {fmt(deposits.reduce((sum, d) => sum + Number(d.amount), 0))}
                      </p>
                    </div>
                    <div className="bg-gradient-to-br from-blue-50 to-indigo-50 rounded-xl p-4 text-center border border-blue-200">
                      <p className="text-xs text-blue-600 mb-1">Dettes remboursées</p>
                      <p className="text-xl font-bold text-blue-700">
                        {fmt(deposits.reduce((sum, d) => sum + Number(d.amount_to_debt), 0))}
                      </p>
                    </div>
                    <div className="bg-gradient-to-br from-violet-50 to-purple-50 rounded-xl p-4 text-center border border-violet-200">
                      <p className="text-xs text-violet-600 mb-1">Solde prépayé</p>
                      <p className="text-xl font-bold text-violet-700">
                        {fmt(deposits.reduce((sum, d) => sum + Number(d.amount_to_prepaid), 0))}
                      </p>
                    </div>
                  </div>

                  {/* Liste des dépôts */}
                  {deposits.map((deposit) => (
                    <div 
                      key={deposit.id}
                      className="bg-white border border-gray-200 rounded-xl overflow-hidden shadow-sm hover:shadow-md transition-shadow"
                    >
                      {/* En-tête du dépôt */}
                      <div className="bg-gradient-to-r from-emerald-500 to-teal-500 px-4 py-3 text-white">
                        <div className="flex items-center justify-between">
                          <div className="flex items-center gap-3">
                            <div className="w-10 h-10 bg-white/20 rounded-lg flex items-center justify-center">
                              <Wallet className="w-5 h-5" />
                            </div>
                            <div>
                              <p className="font-semibold">{deposit.deposit_number}</p>
                              <p className="text-xs text-white/80">
                                {new Date(deposit.created_at).toLocaleDateString('fr-FR', { 
                                  weekday: 'long', day: 'numeric', month: 'long', year: 'numeric',
                                  hour: '2-digit', minute: '2-digit'
                                })}
                              </p>
                            </div>
                          </div>
                          <div className="text-right">
                            <p className="text-2xl font-bold">+{fmt(deposit.amount)}</p>
                            <p className="text-xs text-white/80">
                              {deposit.payment_method === 'especes' ? '💵 Espèces' :
                               deposit.payment_method === 'wave' ? '📱 Wave' :
                               deposit.payment_method === 'orange_money' ? '📱 Orange Money' :
                               deposit.payment_method === 'banque' ? '🏦 Banque' :
                               deposit.payment_method === 'cheque' ? '📝 Chèque' :
                               deposit.payment_method === 'virement' ? '💳 Virement' :
                               deposit.payment_method || 'Espèces'}
                            </p>
                          </div>
                        </div>
                      </div>

                      {/* Détails du dépôt */}
                      <div className="p-4 space-y-4">
                        {/* Résumé du dépôt */}
                        <div className="flex gap-4">
                          {Number(deposit.amount_to_debt) > 0 && (
                            <div className="flex-1 bg-blue-50 rounded-lg p-3 border border-blue-100">
                              <p className="text-xs text-blue-600">Remboursement dette</p>
                              <p className="text-lg font-bold text-blue-700">{fmt(deposit.amount_to_debt)}</p>
                            </div>
                          )}
                          {Number(deposit.amount_to_prepaid) > 0 && (
                            <div className="flex-1 bg-violet-50 rounded-lg p-3 border border-violet-100">
                              <p className="text-xs text-violet-600">Ajouté au solde</p>
                              <p className="text-lg font-bold text-violet-700">{fmt(deposit.amount_to_prepaid)}</p>
                            </div>
                          )}
                        </div>

                        {/* Évolution des soldes */}
                        <div className="flex items-center gap-2 text-sm bg-gray-50 rounded-lg p-3">
                          <div className="flex-1">
                            <p className="text-xs text-gray-500">Dette avant</p>
                            <p className="font-semibold text-red-600">{fmt(deposit.previous_debt)}</p>
                          </div>
                          <ArrowRight className="w-4 h-4 text-gray-400" />
                          <div className="flex-1">
                            <p className="text-xs text-gray-500">Dette après</p>
                            <p className="font-semibold text-green-600">{fmt(deposit.new_debt)}</p>
                          </div>
                          <div className="w-px h-8 bg-gray-300 mx-2"></div>
                          <div className="flex-1">
                            <p className="text-xs text-gray-500">Prépayé avant</p>
                            <p className="font-semibold text-gray-600">{fmt(deposit.previous_prepaid)}</p>
                          </div>
                          <ArrowRight className="w-4 h-4 text-gray-400" />
                          <div className="flex-1">
                            <p className="text-xs text-gray-500">Prépayé après</p>
                            <p className="font-semibold text-emerald-600">{fmt(deposit.new_prepaid)}</p>
                          </div>
                        </div>

                        {/* Allocations - Traçabilité des ventes remboursées */}
                        {deposit.allocations && deposit.allocations.length > 0 && (
                          <div className="border-t border-gray-100 pt-4">
                            <h4 className="text-sm font-semibold text-gray-700 mb-3 flex items-center gap-2">
                              <Receipt className="w-4 h-4 text-blue-500" />
                              Ventes remboursées ({deposit.allocations.length})
                            </h4>
                            <div className="space-y-2">
                              {deposit.allocations.map((alloc, idx) => (
                                <div 
                                  key={idx}
                                  className="bg-gradient-to-r from-blue-50 to-indigo-50 rounded-lg p-3 border border-blue-100"
                                >
                                  <div className="flex items-center justify-between">
                                    <div>
                                      <p className="font-medium text-gray-800">
                                        Vente {alloc.saleNumber}
                                      </p>
                                      <p className="text-xs text-gray-500">
                                        {new Date(alloc.saleDate).toLocaleDateString('fr-FR')} • {alloc.productDetails}
                                      </p>
                                    </div>
                                    <div className="text-right">
                                      <p className="font-bold text-blue-700">
                                        -{fmt(alloc.amountAllocated)}
                                      </p>
                                      <p className="text-xs text-gray-500">
                                        sur {fmt(alloc.saleTotal)}
                                      </p>
                                    </div>
                                  </div>
                                  {/* Barre de progression du paiement */}
                                  <div className="mt-2">
                                    <div className="flex justify-between text-xs text-gray-500 mb-1">
                                      <span>Restant avant: {fmt(alloc.previousBalance)}</span>
                                      <span>Restant après: {fmt(alloc.newBalance)}</span>
                                    </div>
                                    <div className="h-2 bg-gray-200 rounded-full overflow-hidden">
                                      <div 
                                        className="h-full bg-gradient-to-r from-blue-500 to-indigo-500 rounded-full transition-all"
                                        style={{ 
                                          width: `${Math.max(0, Math.min(100, ((alloc.saleTotal - alloc.newBalance) / alloc.saleTotal) * 100))}%` 
                                        }}
                                      />
                                    </div>
                                    {alloc.newBalance === 0 && (
                                      <p className="text-xs text-green-600 font-medium mt-1 flex items-center gap-1">
                                        <CheckCircle2 className="w-3 h-3" />
                                        Vente entièrement payée
                                      </p>
                                    )}
                                  </div>
                                </div>
                              ))}
                            </div>
                          </div>
                        )}

                        {/* Notes et référence */}
                        {(deposit.notes || deposit.reference_number) && (
                          <div className="text-sm text-gray-600 bg-gray-50 rounded-lg p-3">
                            {deposit.reference_number && (
                              <p><span className="font-medium">Référence:</span> {deposit.reference_number}</p>
                            )}
                            {deposit.notes && (
                              <p><span className="font-medium">Notes:</span> {deposit.notes}</p>
                            )}
                          </div>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              ) : (
                /* État vide */
                <div className="text-center py-12 bg-gray-50 rounded-xl border-2 border-dashed border-gray-200">
                  <div className="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <History className="w-8 h-8 text-gray-400" />
                  </div>
                  <h4 className="text-lg font-medium text-gray-600 mb-2">Aucun dépôt enregistré</h4>
                  <p className="text-sm text-gray-500 mb-4">
                    Les dépôts effectués par ce client apparaîtront ici avec leur traçabilité complète
                  </p>
                  <button
                    onClick={onEdit}
                    className="inline-flex items-center gap-2 px-4 py-2 bg-emerald-600 text-white rounded-lg hover:bg-emerald-700 transition-colors"
                  >
                    <Wallet className="w-4 h-4" />
                    Effectuer un dépôt
                  </button>
                </div>
              )}
            </div>
          )}

          {/* Tab: Notes */}
          {activeTab === 'notes' && (
            <div className="space-y-4">
              {/* En-tête */}
              <div className="flex items-center justify-between">
                <h3 className="text-lg font-semibold text-gray-800 flex items-center gap-2">
                  <FileText className="w-5 h-5 text-indigo-500" />
                  Notes internes
                </h3>
                <span className="text-xs text-gray-500 bg-gray-100 px-2 py-1 rounded-full">
                  {notes ? notes.split('\n').filter(l => l.trim()).length : 0} entrée(s)
                </span>
              </div>

              {notes ? (
                <div className="space-y-3">
                  {/* Analyse des notes - Extraction des dépôts */}
                  {(() => {
                    const lines = notes.split('\n').filter(l => l.trim());
                    const depositLines = lines.filter(l => l.includes('Dépôt') || l.includes('Dette'));
                    const otherLines = lines.filter(l => !l.includes('Dépôt') && !l.includes('Dette'));
                    
                    // Calculer les totaux des dépôts et dettes remboursées
                    let totalDeposits = 0;
                    let totalDebtRepaid = 0;
                    depositLines.forEach(line => {
                      const depositMatch = line.match(/\+(\d[\d\s]*)\s*F/);
                      const debtMatch = line.match(/Dette remboursée:\s*(\d[\d\s]*)\s*F/);
                      if (depositMatch) {
                        totalDeposits += parseInt(depositMatch[1].replace(/\s/g, ''));
                      }
                      if (debtMatch) {
                        totalDebtRepaid += parseInt(debtMatch[1].replace(/\s/g, ''));
                      }
                    });

                    return (
                      <>
                        {/* Résumé des transactions financières */}
                        {depositLines.length > 0 && (
                          <div className="bg-gradient-to-r from-emerald-50 to-teal-50 border border-emerald-200 rounded-xl p-4">
                            <div className="flex items-center gap-2 mb-3">
                              <div className="w-8 h-8 bg-emerald-500 rounded-lg flex items-center justify-center">
                                <Wallet className="w-4 h-4 text-white" />
                              </div>
                              <h4 className="font-semibold text-emerald-800">Transactions financières</h4>
                            </div>
                            
                            {/* Stats des transactions */}
                            <div className="grid grid-cols-2 gap-3 mb-4">
                              <div className="bg-white/70 rounded-lg p-3 text-center">
                                <p className="text-xs text-gray-500 mb-1">Total dépôts</p>
                                <p className="text-lg font-bold text-emerald-600">
                                  +{totalDeposits.toLocaleString('fr-FR')} F
                                </p>
                              </div>
                              <div className="bg-white/70 rounded-lg p-3 text-center">
                                <p className="text-xs text-gray-500 mb-1">Dettes remboursées</p>
                                <p className="text-lg font-bold text-blue-600">
                                  {totalDebtRepaid.toLocaleString('fr-FR')} F
                                </p>
                              </div>
                            </div>

                            {/* Liste des transactions */}
                            <div className="space-y-2">
                              {depositLines.map((line, index) => {
                                // Parser la ligne pour extraire les infos
                                const dateMatch = line.match(/(\d{2}\/\d{2}\/\d{4})/);
                                const depositMatch = line.match(/\+(\d[\d\s]*)\s*F/);
                                const debtMatch = line.match(/Dette remboursée:\s*(\d[\d\s]*)\s*F/);
                                
                                return (
                                  <div 
                                    key={index}
                                    className="bg-white rounded-lg p-3 flex items-center justify-between shadow-sm border border-emerald-100"
                                  >
                                    <div className="flex items-center gap-3">
                                      <div className="w-10 h-10 bg-emerald-100 rounded-full flex items-center justify-center">
                                        <TrendingUp className="w-5 h-5 text-emerald-600" />
                                      </div>
                                      <div>
                                        <p className="font-medium text-gray-800">Dépôt</p>
                                        <p className="text-xs text-gray-500">
                                          {dateMatch ? dateMatch[1] : 'Date inconnue'}
                                        </p>
                                      </div>
                                    </div>
                                    <div className="text-right">
                                      {depositMatch && (
                                        <p className="font-bold text-emerald-600">
                                          +{parseInt(depositMatch[1].replace(/\s/g, '')).toLocaleString('fr-FR')} F
                                        </p>
                                      )}
                                      {debtMatch && (
                                        <p className="text-xs text-blue-600">
                                          Dette: -{parseInt(debtMatch[1].replace(/\s/g, '')).toLocaleString('fr-FR')} F
                                        </p>
                                      )}
                                    </div>
                                  </div>
                                );
                              })}
                            </div>
                          </div>
                        )}

                        {/* Autres notes */}
                        {otherLines.length > 0 && (
                          <div className="bg-amber-50 border border-amber-200 rounded-xl p-4">
                            <div className="flex items-center gap-2 mb-3">
                              <div className="w-8 h-8 bg-amber-500 rounded-lg flex items-center justify-center">
                                <FileText className="w-4 h-4 text-white" />
                              </div>
                              <h4 className="font-semibold text-amber-800">Notes générales</h4>
                            </div>
                            <div className="space-y-2">
                              {otherLines.map((line, index) => (
                                <div 
                                  key={index}
                                  className="bg-white rounded-lg p-3 shadow-sm border border-amber-100"
                                >
                                  <p className="text-sm text-gray-700">{line}</p>
                                </div>
                              ))}
                            </div>
                          </div>
                        )}

                        {/* Afficher brut si aucune catégorie détectée */}
                        {depositLines.length === 0 && otherLines.length === 0 && (
                          <div className="bg-gray-50 border border-gray-200 rounded-xl p-4">
                            <p className="text-sm text-gray-700 whitespace-pre-wrap">{notes}</p>
                          </div>
                        )}
                      </>
                    );
                  })()}
                </div>
              ) : (
                /* État vide */
                <div className="text-center py-12 bg-gray-50 rounded-xl border-2 border-dashed border-gray-200">
                  <div className="w-16 h-16 bg-gray-100 rounded-full flex items-center justify-center mx-auto mb-4">
                    <FileText className="w-8 h-8 text-gray-400" />
                  </div>
                  <h4 className="text-lg font-medium text-gray-600 mb-2">Aucune note</h4>
                  <p className="text-sm text-gray-500 mb-4">
                    Ce client n'a pas encore de notes internes
                  </p>
                  <button
                    onClick={() => onEdit && onEdit(customer)}
                    className="inline-flex items-center gap-2 px-4 py-2 bg-indigo-600 text-white rounded-lg hover:bg-indigo-700 transition-colors"
                  >
                    <Edit className="w-4 h-4" />
                    Ajouter une note
                  </button>
                </div>
              )}
            </div>
          )}
        </div>
      </div>
    </div>
  );
};
